# ============================================================
#  aniDB 環境変数テンプレート
#  これらを設定しなくても、シードデータでアプリは起動・閲覧できます。
#  本番（Supabase / Google連携 / 外部API取り込み）を使うときに設定します。
# ============================================================

# --- アプリ ---
# 公開URL（OAuthのリダイレクト先などに使用）。ローカルは下記のまま。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- データソース切替 ---
# "seed" = 同梱のサンプルデータで動作 / "supabase" = Supabaseを使用
DATA_PROVIDER=seed

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用（cron/取り込み/トークン操作）。絶対に公開しない。
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth / Calendar ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 例: http://localhost:3000/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# リフレッシュトークン暗号化用の鍵（32バイトのhex= 64文字）。
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# OAuthのstate/セッション署名用シークレット（任意の長い文字列）
SESSION_SECRET=

# --- Annict ---
# https://annict.com/settings/apps で個人アクセストークンを発行（権限read）
ANNICT_TOKEN=

# --- 内部API（cron）保護用トークン ---
# cronからの呼び出しに付与するヘッダ。任意の長い文字列。
INTERNAL_API_SECRET=
