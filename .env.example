# ============================================================
#  aniDB 環境変数テンプレート
#  これらを設定しなくても、シードデータでアプリは起動・閲覧できます。
#  本番（Supabase / Googleログイン / 外部API取り込み）を使うときに設定します。
# ============================================================

# --- アプリ ---
# 公開URL（OAuthのリダイレクト先・ICS購読URLの組み立てに使用）。ローカルは下記のまま。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- データソース切替 ---
# "seed" = 同梱のサンプルデータで動作 / "supabase" = Supabaseを使用
DATA_PROVIDER=seed

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用（cron/取り込み）。絶対に公開しない。
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth（本人識別のみ: openid email profile。カレンダー権限は使わない） ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 例: http://localhost:3000/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# OAuthのstate/セッション署名用シークレット（任意の長い文字列）
SESSION_SECRET=

# --- Annict ---
# https://annict.com/settings/apps で個人アクセストークンを発行（権限read）
ANNICT_TOKEN=

# Annictにサブタイトルが無い回を しょぼいカレンダー で補完する（true/false）
SYOBOI_BACKFILL=true
