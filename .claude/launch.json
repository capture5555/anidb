{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "anidb-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "anidb-seed",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "-p", "3001"],
      "port": 3001,
      "env": {
        "DATA_PROVIDER": "seed",
        "NEXT_PUBLIC_SUPABASE_URL": "",
        "SUPABASE_SERVICE_ROLE_KEY": "",
        "GOOGLE_CLIENT_ID": "",
        "GOOGLE_CLIENT_SECRET": "",
        "NEXT_PUBLIC_APP_URL": "http://localhost:3001"
      }
    }
  ]
}
